{
	"$schema": "https://opencode.ai/tui.json",
	"theme": "system",
	"keybinds": {
		"messages_page_up": "ctrl+shift+k",
		"messages_page_down": "ctrl+shift+j",
		"messages_line_up": "ctrl+shift+y",
		"messages_line_down": "ctrl+shift+e",
		"messages_half_page_up": "ctrl+shift+u",
		"messages_half_page_down": "ctrl+shift+d",
		"messages_first": "ctrl+g",
		"messages_last": "ctrl+shift+g"
	}
}
